APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=grc_tool_react
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# In production set SESSION_ENCRYPT=true and SESSION_SECURE_COOKIE=true.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Anthropic Claude — required for AI evidence review, risk generation, gap analysis,
# security-config analysis, compliance chatbot. Issue per-environment keys.
ANTHROPIC_API_KEY=

# Gemini Vision (optional image preprocessing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_PREPROCESSING=true

# VirusTotal — file reputation checks for uploaded evidence and security-audit files.
# Paste your VirusTotal v3 API key into VIRUSTOTAL_API_KEY then flip VIRUSTOTAL_ENABLED=true.
# VIRUSTOTAL_UPLOAD_FILES is left false (hash lookup only — no file content leaves the server).
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_ENABLED=false
VIRUSTOTAL_UPLOAD_FILES=false
VIRUSTOTAL_TIMEOUT=15
